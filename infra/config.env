# Configurações compartilhadas pelos scripts de infraestrutura.
# Edite os valores conforme sua conta AWS antes de rodar o deploy.

export AWS_REGION="us-east-2"
export PROJECT_NAME="tech-challenge-fase4"

# Recursos AWS
export DYNAMO_TABLE="Feedbacks"
export SNS_TOPIC_NAME="feedback-notifications"
export ECR_REPOSITORY="${PROJECT_NAME}/feedback-service"

# Lambdas
export LAMBDA_FEEDBACK="TechChallenge"
export LAMBDA_REPORT="gerarRelatorioSemanal"
export LAMBDA_MEMORY=512
export LAMBDA_TIMEOUT_FEEDBACK=30
export LAMBDA_TIMEOUT_REPORT=60

# IAM
export LAMBDA_ROLE_NAME="feedback_lambda_role"

# API Gateway
export API_NAME="feedback-api"
export API_ROUTE="POST /avaliacao"

# EventBridge (todo domingo às 23h59 UTC)
export REPORT_SCHEDULE="cron(59 23 ? * SUN *)"

# E-mail que receberá as notificações (será inscrito no SNS).
# Deixe vazio se preferir confirmar manualmente no console.
export ADMIN_EMAIL=""
